apiVersion: grafana.integreatly.org/v1beta1
kind: GrafanaDashboard
metadata:
  name: platform-command-center
  namespace: monitoring
spec:
  instanceSelector:
    matchLabels:
      dashboards: grafana
  json: |
    {
      "title": "Sovereign Platform Command Center",
      "uid": "platform-command-center",
      "tags": ["platform", "openshift", "command-center"],
      "timezone": "browser",
      "schemaVersion": 38,
      "style": "dark",
      "refresh": "30s",
      "time": {"from": "now-6h", "to": "now"},
      "panels": [
        {
          "id": 1,
          "title": "Platform Health Score",
          "type": "gauge",
          "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
          "options": {
            "reduceOptions": {"calcs": ["lastNotNull"]},
            "showThresholdLabels": false,
            "showThresholdMarkers": true
          },
          "fieldConfig": {
            "defaults": {
              "min": 0,
              "max": 100,
              "unit": "percent",
              "decimals": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "red", "value": null},
                  {"color": "orange", "value": 65},
                  {"color": "green", "value": 85}
                ]
              }
            }
          },
          "targets": [{
            "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
            "expr": "clamp_max(clamp_min(100 - (count(kube_pod_status_phase{phase!=\"Running\",phase!=\"Succeeded\"} == 1) * 3) - (sum(kube_pod_container_status_restarts_total) * 0.05), 0), 100)",
            "instant": true
          }]
        },
        {
          "id": 2,
          "title": "OpenShift Node Readiness",
          "type": "stat",
          "gridPos": {"h": 4, "w": 4, "x": 6, "y": 0},
          "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center"},
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "decimals": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "red", "value": null},
                  {"color": "orange", "value": 6},
                  {"color": "green", "value": 8}
                ]
              }
            }
          },
          "targets": [{
            "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
            "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"true\"})",
            "instant": true
          }]
        },
        {
          "id": 3,
          "title": "Bad Pods",
          "type": "stat",
          "gridPos": {"h": 4, "w": 4, "x": 10, "y": 0},
          "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center"},
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "decimals": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "orange", "value": 1},
                  {"color": "red", "value": 5}
                ]
              }
            }
          },
          "targets": [{
            "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
            "expr": "count(kube_pod_status_phase{phase!=\"Running\",phase!=\"Succeeded\"} == 1)",
            "instant": true
          }]
        },
        {
          "id": 4,
          "title": "ArgoCD Synced Apps",
          "type": "stat",
          "gridPos": {"h": 4, "w": 4, "x": 14, "y": 0},
          "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center"},
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "decimals": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "red", "value": null},
                  {"color": "orange", "value": 18},
                  {"color": "green", "value": 22}
                ]
              }
            }
          },
          "targets": [{
            "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
            "expr": "sum(argocd_app_info{sync_status=\"Synced\"})",
            "instant": true
          }]
        },
        {
          "id": 5,
          "title": "Prometheus Targets Up",
          "type": "stat",
          "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
          "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center"},
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "decimals": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "red", "value": null},
                  {"color": "orange", "value": 70},
                  {"color": "green", "value": 90}
                ]
              }
            }
          },
          "targets": [{
            "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
            "expr": "sum(up)",
            "instant": true
          }]
        },
        {
          "id": 6,
          "title": "Cluster CPU Utilization",
          "type": "timeseries",
          "gridPos": {"h": 8, "w": 9, "x": 6, "y": 4},
          "fieldConfig": {
            "defaults": {"unit": "percentunit", "decimals": 2}
          },
          "targets": [{
            "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
            "expr": "avg(1 - rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))",
            "legendFormat": "cluster cpu"
          }]
        },
        {
          "id": 7,
          "title": "Cluster Memory Utilization",
          "type": "timeseries",
          "gridPos": {"h": 8, "w": 9, "x": 15, "y": 4},
          "fieldConfig": {
            "defaults": {"unit": "percentunit", "decimals": 2}
          },
          "targets": [{
            "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
            "expr": "1 - (sum(node_memory_MemAvailable_bytes) / sum(node_memory_MemTotal_bytes))",
            "legendFormat": "cluster memory"
          }]
        },
        {
          "id": 8,
          "title": "Platform Components",
          "type": "bargauge",
          "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
          "options": {"orientation": "horizontal", "displayMode": "basic", "valueMode": "color"},
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "decimals": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "red", "value": null},
                  {"color": "green", "value": 1}
                ]
              }
            }
          },
          "targets": [
            {
              "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
              "expr": "sum(up{namespace=\"kafka\",job=\"kafka/kafka-resources-metrics\"})",
              "instant": true,
              "legendFormat": "Kafka Brokers"
            },
            {
              "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
              "expr": "sum(up{namespace=\"minio\",job=\"minio\"})",
              "instant": true,
              "legendFormat": "MinIO"
            },
            {
              "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
              "expr": "sum(up{namespace=\"postgresql\",job=\"postgres-exporter\"})",
              "instant": true,
              "legendFormat": "PostgreSQL"
            },
            {
              "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
              "expr": "sum(up{namespace=\"vault\"})",
              "instant": true,
              "legendFormat": "Vault"
            }
          ]
        },
        {
          "id": 9,
          "title": "Kafka Partition Health",
          "type": "timeseries",
          "gridPos": {"h": 8, "w": 8, "x": 8, "y": 12},
          "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}},
          "targets": [{
            "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
            "expr": "sum(kafka_cluster_partition_atminisr_topic_fraud_decisions_partition_0_value)",
            "legendFormat": "fraud decisions ISR"
          }]
        },
        {
          "id": 10,
          "title": "MinIO Usable Capacity",
          "type": "gauge",
          "gridPos": {"h": 8, "w": 8, "x": 16, "y": 12},
          "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
          "fieldConfig": {
            "defaults": {
              "unit": "percentunit",
              "min": 0,
              "max": 1,
              "decimals": 2,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "orange", "value": 0.7},
                  {"color": "red", "value": 0.85}
                ]
              }
            }
          },
          "targets": [{
            "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
            "expr": "1 - (minio_cluster_capacity_usable_free_bytes / minio_cluster_capacity_usable_total_bytes)",
            "instant": true
          }]
        },
        {
          "id": 11,
          "title": "Pod Restarts by Namespace",
          "type": "bargauge",
          "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
          "options": {"orientation": "horizontal", "displayMode": "gradient", "valueMode": "color"},
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "decimals": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "orange", "value": 5},
                  {"color": "red", "value": 20}
                ]
              }
            }
          },
          "targets": [{
            "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
            "expr": "sort_desc(sum by (namespace) (increase(kube_pod_container_status_restarts_total[6h])))",
            "instant": true,
            "legendFormat": "{{namespace}}"
          }]
        },
        {
          "id": 12,
          "title": "Namespace Memory Usage",
          "type": "bargauge",
          "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
          "options": {"orientation": "horizontal", "displayMode": "gradient", "valueMode": "color"},
          "fieldConfig": {
            "defaults": {"unit": "bytes", "decimals": 1}
          },
          "targets": [{
            "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
            "expr": "topk(10, sum by (namespace) (container_memory_working_set_bytes{container!=\"\",namespace!=\"\"}))",
            "instant": true,
            "legendFormat": "{{namespace}}"
          }]
        },
        {
          "id": 13,
          "title": "Fraud Transactions",
          "type": "stat",
          "gridPos": {"h": 5, "w": 6, "x": 0, "y": 28},
          "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center"},
          "fieldConfig": {
            "defaults": {"unit": "short", "decimals": 0}
          },
          "targets": [{
            "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
            "expr": "fraud_total_transactions_all",
            "instant": true
          }]
        },
        {
          "id": 14,
          "title": "Fraud Cases Detected",
          "type": "stat",
          "gridPos": {"h": 5, "w": 6, "x": 6, "y": 28},
          "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center"},
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "decimals": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "orange", "value": 10000},
                  {"color": "red", "value": 30000}
                ]
              }
            }
          },
          "targets": [{
            "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
            "expr": "fraud_total_fraud_count_all",
            "instant": true
          }]
        },
        {
          "id": 15,
          "title": "Average Fraud Rate",
          "type": "stat",
          "gridPos": {"h": 5, "w": 6, "x": 12, "y": 28},
          "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center"},
          "fieldConfig": {
            "defaults": {
              "unit": "percentunit",
              "decimals": 2,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "orange", "value": 0.03},
                  {"color": "red", "value": 0.07}
                ]
              }
            }
          },
          "targets": [{
            "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
            "expr": "fraud_avg_fraud_rate_all",
            "instant": true
          }]
        },
        {
          "id": 16,
          "title": "Silver Decisions",
          "type": "stat",
          "gridPos": {"h": 5, "w": 6, "x": 18, "y": 28},
          "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center"},
          "fieldConfig": {
            "defaults": {"unit": "short", "decimals": 0}
          },
          "targets": [{
            "datasource": {"type": "prometheus", "uid": "9e5b7c92-d205-4816-8962-8d8856c180b8"},
            "expr": "fraud_silver_decisions_count",
            "instant": true
          }]
        }
      ]
    }
